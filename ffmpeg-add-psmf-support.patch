+    .priv_data_size = sizeof(PsmfContext),
+    .flags_internal = FF_INFMT_FLAG_INIT_CLEANUP,
+    .read_probe     = psmf_probe,
+    .read_header    = psmf_read_header,
+    .read_packet    = psmf_read_packet,
+    .read_timestamp = mpegps_read_dts
+};
