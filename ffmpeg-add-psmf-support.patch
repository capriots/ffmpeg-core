+        ff_dlog(avctx,
+                "pcm_bluray_parse_header: %d channels, %d bits per sample, %d Hz, %"PRId64" bit/s\n",
+                avctx->ch_layout.nb_channels, avctx->bits_per_coded_sample,
+                avctx->sample_rate, avctx->bit_rate);
